# Docker on VPS (shared PostgreSQL on network infra):
# DATABASE_URL=postgresql://postgres:<password>@postgresql:5432/weather
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/weather
SECRET_KEY=dev-secret-change-in-production
# In-process APScheduler (local dev). Docker Compose uses a separate worker instead.
SCHEDULER_ENABLED=true
FLASK_APP=wsgi:app
FLASK_DEBUG=0
